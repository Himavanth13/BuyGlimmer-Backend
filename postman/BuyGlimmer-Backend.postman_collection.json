    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const now = Date.now();",
                  "const rand = Math.floor(Math.random() * 10000).toString().padStart(4, '0');",
                  "const reqId = `req-${now}-${rand}`;",
                  "const email = `postman.user.${now}.${rand}@example.com`;",
                  "const phone = `9${Math.floor(100000000 + Math.random() * 900000000)}`;",
                  "pm.collectionVariables.set('requestId', reqId);",
                  "pm.collectionVariables.set('registerEmail', email);",
                  "pm.collectionVariables.set('registerPhone', phone);",
                  "console.log('Register payload vars set', { requestId: reqId, registerEmail: email, registerPhone: phone });"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"\",\n  \"requestId\": \"{{requestId}}\",\n  \"data\": {\n    \"name\": \"{{registerName}}\",\n    \"email\": \"{{registerEmail}}\",\n    \"password\": \"{{registerPassword}}\",\n    \"phone\": \"{{registerPhone}}\"\n  }\n}"
            },
            "url": "{{baseUrl}}/api/v1/auth/register"
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
